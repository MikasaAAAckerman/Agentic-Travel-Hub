    {
      "title": "Agent 调用趋势",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(agent_invoke_total[5m])",
          "legendFormat": "Agent 调用速率"
        },
        {
          "expr": "rate(tool_call_total[5m])",
          "legendFormat": "工具调用速率"
        },
        {
          "expr": "rate(agent_clarify_total[5m])",
          "legendFormat": "CLARIFY 速率"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    }
