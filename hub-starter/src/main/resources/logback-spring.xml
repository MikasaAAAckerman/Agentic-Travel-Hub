<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 引入 Spring Boot 默认配置 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ==================== 控制台输出（开发环境） ==================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- 带颜色的可读格式，方便本地开发 -->
            <pattern>%d{HH:mm:ss.SSS} [%highlight(%-5level)] [%yellow(%X{traceId:-})] [%cyan(%X{agentName:-})] [%green(%X{eventType:-})] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ==================== 文件输出（JSON 结构化） ==================== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE:-./logs/travel-hub.log}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE:-./logs/travel-hub}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <!-- JSON 结构化格式，方便 ELK/Loki 采集 -->
            <pattern>{"timestamp":"%d{yyyy-MM-dd HH:mm:ss.SSS}","level":"%level","traceId":"%X{traceId:-}","agentName":"%X{agentName:-}","round":"%X{round:-}","isRetry":"%X{isRetry:-}","eventType":"%X{eventType:-}","logger":"%logger{36}","thread":"%thread","msg":"%msg"}%n</pattern>
        </encoder>
    </appender>

    <!-- ==================== 日志级别配置 ==================== -->

    <!-- 开发环境：控制台 + 文件，DEBUG 级别 -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.travel" level="DEBUG"/>
    </springProfile>

    <!-- 生产环境：仅文件，INFO 级别 -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.travel" level="INFO"/>
    </springProfile>

    <!-- 默认：控制台 + 文件 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
